# Admin dashboard password — set a STRONG value in production
ADMIN_PASSWORD=amber

# Secret for signing session cookies — set to a long random string in production
SESSION_SECRET=change-me

# Cloudflare R2 storage (photos + db). When all four are set, the app uses R2;
# otherwise it falls back to local disk for development.
# From the Cloudflare dashboard: R2 → Manage R2 API Tokens → create a token.
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Google Photos Picker API (optional — only if using Google Photos import)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
